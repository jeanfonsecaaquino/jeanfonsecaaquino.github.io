---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout title="JEAN FONSECA | SOFTWARE ENGINEER">
	<main class="container py-12 lg:py-24">
		<!-- Header / Nav area -->
		<div class="flex justify-end items-center mb-12 px-2 animate-fade-in">
			<nav
				class="hidden md:flex gap-8 text-[10px] font-bold tracking-[0.2em] text-zinc-500 items-center"
			>
				<a href="#" class="hover:text-white transition-colors">INÍCIO</a
				>
				<a
					href="/Profile.pdf"
					download
					class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-white hover:bg-white hover:text-black transition-all"
					>DOWNLOAD CV</a
				>
			</nav>
		</div>

		<div
			class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-9 gap-6 min-h-[1200px]"
		>
			<!-- Hero Section -->
			<Card
				className="md:col-span-3 md:row-span-2 flex flex-col justify-center order-1"
				delay={0.1}
			>
				<div
					class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 mb-6 w-fit"
				>
					<span class="relative flex h-2 w-2">
						<span
							class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
						></span>
						<span
							class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
						></span>
					</span>
					<p
						class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest"
					>
						Disponível para Projetos
					</p>
				</div>
				<h1
					class="text-6xl md:text-8xl font-black leading-[0.9] mb-8 tracking-tighter italic uppercase"
				>
					Software<br /><span class="text-neon pointer-events-none"
						>Engineer.</span
					>
				</h1>
				<p
					class="text-zinc-400 text-xl max-w-xl font-medium leading-relaxed"
				>
					Especialista em <span class="text-white italic"
						>Sistemas Distribuídos</span
					>, Cloud e Backend com mais de 10 anos de jornada
					tecnológica.
				</p>
			</Card>

			<!-- Profile Info -->
			<Card
				className="md:col-span-1 md:row-span-2 flex flex-col items-center justify-center text-center overflow-hidden order-2"
				delay={0.2}
			>
				<div
					class="relative w-full h-full flex flex-col items-center justify-center p-8"
				>
					<div
						class="w-32 h-32 bg-zinc-900 rounded-full mb-6 relative group-hover:scale-110 transition-transform duration-700 ring-1 ring-white/10 overflow-hidden"
					>
						<img
							src="/assets/profile.jpg"
							alt="Jean Fonseca"
							class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
						/>
						<div
							class="absolute inset-0 flex items-center justify-center text-4xl font-black text-white/5 -z-10"
						>
							JF
						</div>
						<!-- Glow effect -->
						<div
							class="absolute -inset-4 bg-emerald-500/20 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
						>
						</div>
					</div>
					<h2 class="text-2xl font-black mb-1 text-white">
						JEAN FONSECA
					</h2>
					<p
						class="text-emerald-500 text-[9px] font-bold tracking-[0.3em] uppercase mb-6"
					>
						Rio de Janeiro, Brasil
					</p>

					<!-- Social Icons Integrated -->
					<div class="flex gap-4 items-center justify-center">
						<a
							href="https://github.com/jeanfonsecaaquino"
							target="_blank"
							class="text-zinc-500 hover:text-neon transition-all hover:scale-125 duration-300"
							title="GitHub"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-github"
								><path
									d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.2-.3 2.4 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
								></path><path d="M9 18c-4.51 2-5-2-7-2"></path>
							</svg>
						</a>
						<a
							href="https://www.linkedin.com/in/jeanfonseca"
							target="_blank"
							class="text-zinc-500 hover:text-neon transition-all hover:scale-125 duration-300"
							title="LinkedIn"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-linkedin"
								><path
									d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
								></path><rect width="4" height="12" x="2" y="9"
								></rect><circle cx="4" cy="4" r="2"></circle>
							</svg>
						</a>
						<a
							href="mailto:jean.fonseca.aquino@gmail.com"
							class="text-zinc-500 hover:text-neon transition-all hover:scale-125 duration-300"
							title="Email"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-mail"
								><rect width="20" height="16" x="2" y="4" rx="2"
								></rect><path
									d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
								></path>
							</svg>
						</a>
					</div>
				</div>
			</Card>

			<!-- About Me Section -->
			<Card
				className="md:col-span-4 md:row-span-1 flex flex-col justify-center order-3 md:col-start-1"
				title="Sobre Mim"
				delay={0.3}
			>
				<p class="text-zinc-400 text-sm leading-relaxed mb-4">
					Olá! Sou o <span class="text-white font-bold"
						>Jean Fonseca</span
					>, um Engenheiro de Software apaixonado por transformar
					desafios técnicos complexos em soluções escaláveis e
					eficientes.
				</p>
				<p class="text-zinc-500 text-sm leading-relaxed">
					Atualmente no <span class="text-white">Mercado Livre</span>,
					trago um histórico sólido em setores críticos como
					financeiro, varejo e saúde. Minha expertise reside em
					arquiteturas distribuídas, microsserviços e governança de
					cloud, sempre com foco em alta disponibilidade e
					performance.
				</p>
			</Card>

			<!-- Backend Stack -->
			<Card
				className="md:col-span-2 md:row-span-1 order-6 md:col-start-3"
				title="Backend"
				delay={0.4}
			>
				<div class="grid grid-cols-2 md:grid-cols-3 gap-3 pt-2">
					{
						[
							"Kotlin",
							"Node.js",
							"Go",
							"Java",
							"Python",
							"TypeScript",
						].map((tech) => (
							<span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-zinc-400 hover:text-neon hover:border-neon/30 transition-all cursor-default uppercase text-center">
								{tech}
							</span>
						))
					}
				</div>
			</Card>

			<!-- Cloud Stack -->
			<Card
				className="md:col-span-2 md:row-span-1 order-7 md:col-start-3"
				title="Cloud & Infra"
				delay={0.5}
			>
				<div class="grid grid-cols-2 md:grid-cols-3 gap-3 pt-2">
					{
						[
							"AWS",
							"EKS",
							"Lambda",
							"Terraform",
							"Docker",
							"SQS",
							"SNS",
							"EC2",
							"Gateway",
						].map((tech) => (
							<span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-zinc-400 hover:text-neon hover:border-neon/30 transition-all cursor-default uppercase text-center">
								{tech}
							</span>
						))
					}
				</div>
			</Card>

			<!-- Experience Stats -->
			<Card
				className="md:col-span-1 md:row-span-1 flex flex-col justify-center text-center group order-4 md:col-start-1"
				delay={0.6}
			>
				<span
					class="text-6xl font-black tracking-tighter text-white group-hover:text-neon transition-colors duration-500"
					>12</span
				>
				<span
					class="text-zinc-500 text-[9px] font-bold uppercase mt-2 tracking-widest"
					>Anos Exp.</span
				>
			</Card>

			<!-- Projects Count -->
			<Card
				className="md:col-span-1 md:row-span-1 flex flex-col justify-center text-center group order-5 md:col-start-2"
				delay={0.7}
			>
				<span
					class="text-6xl font-black tracking-tighter text-white group-hover:text-neon transition-colors duration-500"
					>50+</span
				>
				<span
					class="text-zinc-500 text-[9px] font-bold uppercase mt-2 tracking-widest"
					>Entregas</span
				>
			</Card>

			<!-- Frontend Stack -->
			<Card
				className="md:col-span-2 md:row-span-1 order-8 md:col-start-3"
				title="Frontend"
				delay={0.8}
			>
				<div class="grid grid-cols-2 md:grid-cols-3 gap-3 pt-2">
					{
						["Angular", "React", "Vue", "HTML5", "CSS3"].map(
							(tech) => (
								<span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-zinc-400 hover:text-neon hover:border-neon/30 transition-all cursor-default uppercase text-center">
									{tech}
								</span>
							)
						)
					}
				</div>
			</Card>

			<!-- Data & Messaging -->
			<Card
				className="md:col-span-2 md:row-span-1 md:col-start-3 order-9"
				title="Data & Messaging"
				delay={0.9}
			>
				<div class="grid grid-cols-2 md:grid-cols-3 gap-3 pt-2">
					{
						["PostgreSQL", "MongoDB", "MySQL", "QLDB", "Kafka"].map(
							(tech) => (
								<span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-zinc-400 hover:text-neon hover:border-neon/30 transition-all cursor-default uppercase text-center">
									{tech}
								</span>
							)
						)
					}
				</div>
			</Card>

			<!-- AI & Workflow -->
			<Card
				className="md:col-span-2 md:row-span-1 md:col-start-3 order-10"
				title="IA & Workflow"
				delay={1.0}
			>
				<div class="grid grid-cols-2 md:grid-cols-3 gap-3 pt-2">
					{
						[
							"Cursor",
							"WindSurf",
							"Claude Code",
							"Antigravity",
							"Gemini",
							"NoteBookLM",
							"Spec Driven Dev",
						].map((tech) => (
							<span class="px-4 py-2 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-zinc-400 hover:text-neon hover:border-neon/30 transition-all cursor-default uppercase text-center">
								{tech}
							</span>
						))
					}
				</div>
			</Card>
		</div>

		<footer class="mt-24 pb-12 text-center">
			<p
				class="text-[10px] font-bold text-zinc-600 tracking-[0.5em] uppercase"
			>
				© 2026 JEAN FONSECA — TODOS OS DIREITOS RESERVADOS
			</p>
		</footer>
	</main>

	<script>
		// Lightweight Entrance Animation Script
		const observerOptions = {
			threshold: 0.1,
			rootMargin: "0px 0px -50px 0px",
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const el = entry.target as HTMLElement;
					const delay = el.getAttribute("data-delay") || "0";
					el.style.setProperty("--delay", `${delay}s`);
					el.classList.add("visible");
					observer.unobserve(el);
				}
			});
		}, observerOptions);

		document
			.querySelectorAll(".reveal")
			.forEach((el) => observer.observe(el));
	</script>
</Layout>

<style>
	.tracking-tighter {
		letter-spacing: -0.05em;
	}
	.italic {
		font-style: italic;
	}
</style>
